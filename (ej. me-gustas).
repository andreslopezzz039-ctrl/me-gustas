<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Me gustas 😍</title>
<style>
  body {
    margin: 0;
    padding: 0;
    height: 100vh;
    background: url('https://i.ibb.co/mczVbDC/corazones-acuarela.jpg') no-repeat center center/cover;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: 'Segoe UI', sans-serif;
    overflow: hidden;
  }
  .mensaje {
    background: rgba(255, 255, 255, 0.6);
    padding: 20px 30px;
    border-radius: 20px;
    font-size: 2em;
    font-weight: bold;
    text-align: center;
    color: #d60000;
    backdrop-filter: blur(4px);
    animation: aparecer 2s ease-in-out;
  }
  @keyframes aparecer {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
</head>
<body>
  <div class="mensaje">Me gustas 😍</div>
</body>
</html>
